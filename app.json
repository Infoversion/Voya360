{
  "expo": {
    "name": "Voya360",
    "slug": "voya360",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "voya360",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1B3E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.voya360.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Voya360 uses your location to pre-fill your nearest airport."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.voya360.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-dev-client",
      ["@stripe/stripe-react-native", {
        "merchantIdentifier": "merchant.com.voya360.app",
        "enableGooglePay": false
      }]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f88408ac-e391-4876-84e7-8f7c814c785d"
      }
    },
    "owner": "infoversion"
  }
}
